# Copy to .env. WXT_PUBLIC_* vars are inlined into the extension bundle.
#
# Fanguard API base the background worker proxies fixture resolution through.
# When set, requests go to <base>/api/fixtures (runs in Dublin → dodges the
# Polymarket US geofence). When unset, the worker calls Polymarket's Gamma API
# directly. The install script sets this for you, so you usually don't need .env:
#   pnpm install:prod  → https://www.fanguard.app
#   pnpm install:dev   → http://localhost:3000
WXT_PUBLIC_API_URL="http://localhost:3000"
