# Copy to .env.local and fill in.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Dynamic embedded-wallet environment ID.
# Get one at https://app.dynamic.xyz (Developers → Overview → Environment ID).
# Enable EVM + embedded wallets, and add the Polygon mainnet network.
NEXT_PUBLIC_DYNAMIC_ENVIRONMENT_ID=""

# ── Dynamic Fireblocks Flow (premium payment) ────────────────────────────────
# Environment API token (dyn_…) used server-side to create the Flow checkout.
# app.dynamic.xyz → Developers → API Tokens. Flow must be enabled on the env
# (enterprise / ETHGlobal hackathon). Without it, the checkout page still loads
# but paying returns a 501 with setup hints.
DYNAMIC_API_TOKEN=""

# Optional. Where settled USDC lands. Defaults to the Fanguard treasury wallet
# (0x68b38Be77c460A4451D651874cE10fd42cfe698B). Point at the CoverPool contract
# once it ships.
# FLOW_SETTLEMENT_ADDRESS=""

# Optional. Reuse a Flow checkout id created out-of-band to skip create-on-first-pay.
# FLOW_CHECKOUT_ID=""

# TEST ONLY. Cap the actual charge to this USD amount (the real premium still
# frames the UI). Handy for testing real settlement with pocket change. Remove
# once the Polymarket-funded payout is live so fans pay the true premium.
NEXT_PUBLIC_FLOW_TEST_PREMIUM_USD="0.05"
