# Trading wallet for placing Polymarket (CLOB V2) orders.
# Generate a throwaway key with `cast wallet new`, fund it with a little POL
# (gas) + pUSD (collateral, post-2026-04-28 migration). NEVER commit a funded key.
PRIVATE_KEY=

# Polygon mainnet RPC. polygon-rpc.com is gated; this PublicNode endpoint is open.
POLYGON_RPC_URL=https://polygon-bor-rpc.publicnode.com
