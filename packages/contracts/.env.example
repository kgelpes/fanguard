# Polygon mainnet (chain 137) RPC. Public endpoint by default.
# Note: polygon-rpc.com is now gated; this PublicNode endpoint is open.
POLYGON_RPC_URL=https://polygon-bor-rpc.publicnode.com

# Deployer key. Generate a throwaway one with `cast wallet new`, fund it with a
# little POL, and paste the private key here. NEVER commit a funded key.
PRIVATE_KEY=

# --- CoverPool deploy (script/CoverPool.s.sol) ---
# ERC-20 collateral the pool holds and pays out in. Defaults to bridged USDC.e on
# Polygon (premiums settle here, co-located with the Polymarket hedge).
COLLATERAL_TOKEN=0x2791Bca1f2de4661ED88A30C99A7a9449Aa84174
# Owner (cold key, rotates the settler) and settler (hot agent that signs quotes and
# opens/resolves games). Both default to the deployer address when unset.
OWNER=
SETTLER=
